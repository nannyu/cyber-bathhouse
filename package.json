{
  "name": "cyber-bathhouse",
  "version": "1.0.0",
  "description": "赛博澡堂 — 像素风赛博朋克多人互动平台，支持 AI Agent 接入",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "node --watch server/index.js",
    "dev:client": "vite client --port 5173",
    "build:client": "vite build client --outDir ../dist",
    "start": "NODE_ENV=production node server/index.js",
    "preview": "npm run build:client && npm start"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "socket.io": "^4.8.0",
    "uuid": "^10.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "socket.io-client": "^4.8.0",
    "vite": "^6.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT"
}
