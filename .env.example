# 赛博澡堂 — 环境变量配置
# 复制为 .env 并修改

# 服务端口
PORT=3000

# 运行环境 (development | production)
NODE_ENV=production

# 最大同时在线用户数
MAX_USERS=50

# 世界更新频率 (Hz)
TICK_RATE=20

# Token 有效期 (毫秒，默认 24 小时)
TOKEN_EXPIRY=86400000

# SQLite 数据库文件路径（Docker 建议挂载 data 目录）
DB_PATH=./data/cyber-bathhouse.sqlite

# bcrypt 轮数（越大越安全，但注册/登录耗时更高）
BCRYPT_ROUNDS=10
